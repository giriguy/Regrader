# --- Local LLM (dflash via z-lab/dflash + FastAPI wrapper) ---
# Run in a separate terminal — see README "Setup" section:
#   source .dflash/dflash/.venv/bin/activate
#   python .dflash/server.py \
#     --target mlx-community/Qwen3.5-9B-MLX-4bit \
#     --draft  z-lab/Qwen3.5-9B-DFlash \
#     --port 8000

DFLASH_BASE_URL=http://127.0.0.1:8000/v1
DFLASH_MODEL=mlx-community/Qwen3.5-9B-MLX-4bit

# Optional: backend port (default 3001)
# PORT=3001
